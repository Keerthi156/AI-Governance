# Copy to terraform.tfvars (do not commit secrets).
# Or export TF_VAR_jwt_secret_key / TF_VAR_groq_api_key instead.

project_name = "ai-gov"
environment  = "prod"
aws_region   = "us-east-1"

# Cost tip for first deploy: set false to skip NAT (~$32/mo) and run tasks in public subnets.
enable_nat_gateway = true

db_instance_class = "db.t4g.micro"

# HA: set true for Multi-AZ standby (roughly 2x DB instance cost). Recommended for prod.
db_multi_az = false
# db_backup_retention_days = 7
# db_deletion_protection   = true

backend_desired_count  = 1
frontend_desired_count = 1

jwt_secret_key = "REPLACE_WITH_LONG_RANDOM_SECRET"

# Optional provider keys
groq_api_key      = ""
openai_api_key    = ""
anthropic_api_key = ""
google_api_key    = ""

# HTTPS (optional). Leave empty for HTTP-only on ALB DNS.
# When set, also set hosted_zone_id (Route53) OR provide acm_certificate_arn.
# domain_name     = "app.example.com"
# hosted_zone_id  = "ZXXXXXXXXXXXXX"
# acm_certificate_arn = ""  # optional existing cert in the same region

# WAF (optional). Managed rules + per-IP rate limit on the ALB.
enable_waf     = false
# waf_rate_limit = 2000

# GitHub Actions OIDC (optional). Prefer over static AWS_ACCESS_KEY_ID secrets.
# enable_github_oidc         = true
# github_repository          = "your-org/AI_Governance"
# create_github_oidc_provider = true   # false if account already has GitHub OIDC
# github_oidc_subject_patterns = ["*"] # or ["ref:refs/heads/main"]

# ALB ingress allowlist (optional lockdown). Default is open to the internet.
# alb_ingress_cidr_blocks = ["203.0.113.0/24", "198.51.100.10/32"]
# alb_ingress_ipv6_cidr_blocks = []

# CloudWatch alarms (optional). Confirm the SNS email subscription after apply.
# enable_cloudwatch_alarms  = true
# alarm_notification_email  = "ops@example.com"
# alarm_alb_5xx_threshold   = 10
# alarm_ecs_cpu_threshold   = 80
# alarm_rds_cpu_threshold   = 80
# alarm_rds_free_storage_bytes = 2147483648  # 2 GiB

# AWS Budgets (optional). Account-level monthly COST limit.
# enable_aws_budget         = true
# monthly_budget_usd        = 100
# budget_notification_email = "ops@example.com"  # else uses alarm_notification_email
