# =============================================================================
# Backend runtime configuration
# Copy to backend/.env and fill in values. Do not commit backend/.env.
# =============================================================================

APP_NAME=AI_GOVERNANCE
APP_ENV=development
DEBUG=true

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Local Docker Compose DB uses host `db` and port 5432.
# Native local Postgres often uses 127.0.0.1:5433.
DATABASE_URL=postgresql+psycopg2://ai_governance:CHANGE_ME_DB_PASSWORD@127.0.0.1:5433/ai_governance

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# Optional Fernet material for BYOK org provider keys (defaults to JWT_SECRET_KEY)
CREDENTIAL_ENCRYPTION_KEY=

# LLM provider keys (leave empty until you add your own)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# API rate limiting (in-memory sliding window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LLM_REQUESTS=30
RATE_LIMIT_LLM_WINDOW_SECONDS=60

# Scheduled retention purge (opt-in per org via Retention panel)
RETENTION_SCHEDULER_ENABLED=true
RETENTION_SCHEDULER_INTERVAL_SECONDS=3600
RETENTION_SCHEDULER_INITIAL_DELAY_SECONDS=30

# Webhook delivery retries
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_RETRY_BASE_SECONDS=30
WEBHOOK_RETRY_WORKER_ENABLED=true
WEBHOOK_RETRY_WORKER_INTERVAL_SECONDS=15
WEBHOOK_RETRY_WORKER_INITIAL_DELAY_SECONDS=10
