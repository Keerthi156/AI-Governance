# =============================================================================
# AI_GOVERNANCE — Environment Variable Template
# Copy values into backend/.env and frontend/.env.local as appropriate.
# Never commit real secrets.
# =============================================================================

# --- Application ---
APP_NAME=AI_GOVERNANCE
APP_ENV=development
DEBUG=true

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Database (PostgreSQL) ---
# Local native PG often uses 5433; Docker Compose uses db:5432
DATABASE_URL=postgresql+psycopg2://ai_governance:CHANGE_ME_DB_PASSWORD@127.0.0.1:5433/ai_governance

# --- JWT (Phase 3) ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# Optional Fernet material for BYOK org provider keys (defaults to JWT_SECRET_KEY)
CREDENTIAL_ENCRYPTION_KEY=

# Scheduled retention purge (daemon; only orgs with auto-purge enabled)
RETENTION_SCHEDULER_ENABLED=true
RETENTION_SCHEDULER_INTERVAL_SECONDS=3600
RETENTION_SCHEDULER_INITIAL_DELAY_SECONDS=30

# Webhook delivery retries
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_RETRY_BASE_SECONDS=30
WEBHOOK_RETRY_WORKER_ENABLED=true
WEBHOOK_RETRY_WORKER_INTERVAL_SECONDS=15
WEBHOOK_RETRY_WORKER_INITIAL_DELAY_SECONDS=10

# --- LLM Providers (Phase 1+ integrations) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
